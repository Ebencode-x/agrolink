{% extends "base.html" %}
{% block title %}AgroLink Tanzania — Jukwaa la Kilimo la Kisasa 🌾{% endblock %}

{% block extra_head %}
<style>
  .hero{min-height:calc(100vh - 70px);display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;padding:4rem clamp(1rem,5vw,4rem);max-width:1400px;margin:0 auto}
  .hero-content{animation:slide-up 0.8s cubic-bezier(0.4,0,0.2,1) both}
  @keyframes slide-up{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
  .hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.35);color:var(--emerald-glow);padding:0.35rem 1rem;border-radius:50px;font-size:0.8rem;font-weight:700;margin-bottom:1.5rem;letter-spacing:0.05em;animation:pulse-badge 3s ease-in-out infinite}
  @keyframes pulse-badge{0%,100%{box-shadow:0 0 0 0 rgba(52,211,153,0)}50%{box-shadow:0 0 0 6px rgba(52,211,153,0)}}
  .hero-title{font-family:var(--font-display);font-size:clamp(2.5rem,5vw,4.2rem);font-weight:800;line-height:1.1;margin-bottom:1.5rem}
  .hero-title .accent{background:linear-gradient(135deg,var(--emerald-glow),var(--amber-warm));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .hero-subtitle{font-size:1.1rem;color:var(--text-secondary);line-height:1.7;margin-bottom:2.5rem;max-width:480px}
  .hero-actions{display:flex;gap:1rem;flex-wrap:wrap}
  .btn-primary{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,var(--emerald-bright),#059669);color:white;padding:0.85rem 2rem;border-radius:50px;font-family:var(--font-display);font-weight:600;font-size:0.95rem;text-decoration:none;border:none;cursor:pointer;transition:transform var(--transition),box-shadow var(--transition);box-shadow:0 4px 20px rgba(16,185,129,0.35)}
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(16,185,129,0.5)}
  .btn-ghost{display:inline-flex;align-items:center;gap:8px;background:var(--glass-bg);backdrop-filter:blur(10px);color:var(--text-primary);padding:0.85rem 2rem;border-radius:50px;font-family:var(--font-display);font-weight:500;font-size:0.95rem;text-decoration:none;border:1px solid var(--glass-border);cursor:pointer;transition:all var(--transition)}
  .btn-ghost:hover{background:rgba(255,255,255,0.12);transform:translateY(-1px)}
  .hero-stats{display:flex;gap:2rem;margin-top:3rem;padding-top:2.5rem;border-top:1px solid var(--glass-border)}
  .stat-value{font-family:var(--font-display);font-size:1.8rem;font-weight:800;background:linear-gradient(135deg,var(--emerald-glow),var(--amber-warm));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .stat-label{font-size:0.78rem;color:var(--text-muted);margin-top:2px}
  .hero-visual{animation:slide-up 0.8s 0.2s cubic-bezier(0.4,0,0.2,1) both;display:flex;flex-direction:column;gap:1.5rem}
  .weather-card{padding:2rem;border-radius:var(--radius-lg);position:relative;overflow:hidden}
  .weather-card::before{content:'';position:absolute;top:-40px;right:-40px;width:200px;height:200px;background:radial-gradient(circle,rgba(14,165,233,0.2),transparent 70%);border-radius:50%}
  .weather-temp{font-family:var(--font-display);font-size:4rem;font-weight:800;line-height:1;color:var(--sky-pale)}
  .weather-detail{display:flex;align-items:center;gap:6px;font-size:0.85rem;color:var(--text-secondary)}
  .live-dot{width:8px;height:8px;background:var(--emerald-bright);border-radius:50%;animation:pulse-dot 2s ease-in-out infinite}
  @keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.7)}}
  .price-item{display:flex;align-items:center;justify-content:space-between;padding:0.5rem 0.7rem;border-radius:10px;background:rgba(255,255,255,0.04);transition:background var(--transition)}
  .price-item:hover{background:rgba(255,255,255,0.08)}
  .price-value{font-family:var(--font-display);font-weight:700;font-size:0.9rem;color:var(--emerald-glow)}
  section{padding:5rem clamp(1rem,5vw,4rem);max-width:1400px;margin:0 auto}
  .section-eyebrow{font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--emerald-bright);margin-bottom:0.75rem}
  .section-title{font-family:var(--font-display);font-size:clamp(1.8rem,3vw,2.8rem);font-weight:800;line-height:1.2;margin-bottom:1rem}
  .section-subtitle{font-size:1.05rem;color:var(--text-secondary);max-width:560px;margin:0 auto;line-height:1.7}
  .features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem}
  .feature-card{padding:2rem;border-radius:var(--radius-md);transition:transform var(--transition);position:relative;overflow:hidden}
  .feature-card::before{content:'';position:absolute;inset:0;border-radius:var(--radius-md);background:linear-gradient(135deg,rgba(16,185,129,0.08) 0%,transparent 60%);opacity:0;transition:opacity var(--transition)}
  .feature-card:hover{transform:translateY(-4px)}
  .feature-card:hover::before{opacity:1}
  .feature-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;background:linear-gradient(135deg,rgba(16,185,129,0.2),rgba(16,185,129,0.05));border:1px solid rgba(16,185,129,0.25);color:var(--emerald-bright)}
  .feature-icon.amber{background:linear-gradient(135deg,rgba(245,158,11,0.2),rgba(245,158,11,0.05));border-color:rgba(245,158,11,0.25);color:var(--amber-warm)}
  .feature-icon.sky{background:linear-gradient(135deg,rgba(14,165,233,0.2),rgba(14,165,233,0.05));border-color:rgba(14,165,233,0.25);color:var(--sky-cool)}
  .feature-title{font-family:var(--font-display);font-weight:700;font-size:1.05rem;margin-bottom:0.6rem}
  .feature-desc{font-size:0.88rem;color:var(--text-secondary);line-height:1.65}
  .listings-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem}
  .listing-card{padding:1.5rem;border-radius:var(--radius-md);transition:transform var(--transition);cursor:pointer}
  .listing-card:hover{transform:translateY(-3px)}
  .listing-crop-badge{background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);color:var(--emerald-glow);padding:0.3rem 0.8rem;border-radius:50px;font-size:0.78rem;font-weight:600}
  .listing-meta-value{font-family:var(--font-display);font-weight:700;font-size:0.95rem;color:var(--amber-warm)}
  .listing-contact-btn{display:flex;align-items:center;gap:6px;background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.25);color:var(--emerald-bright);padding:0.5rem 1rem;border-radius:50px;font-size:0.82rem;font-weight:600;cursor:pointer;transition:all var(--transition);margin-top:1rem;width:fit-content}
  .listing-contact-btn:hover{background:rgba(16,185,129,0.2)}
  .weather-input{flex:1;background:rgba(255,255,255,0.06);border:1px solid var(--glass-border);border-radius:50px;padding:0.7rem 1.2rem;color:var(--text-primary);font-family:var(--font-body);font-size:0.9rem;outline:none;transition:border-color var(--transition)}
  .weather-input:focus{border-color:var(--emerald-bright)}
  .weather-input::placeholder{color:var(--text-muted)}
  .weather-btn{background:linear-gradient(135deg,var(--emerald-bright),#059669);border:none;border-radius:50px;padding:0.7rem 1.4rem;color:white;font-family:var(--font-display);font-weight:600;font-size:0.875rem;cursor:pointer;transition:all var(--transition);display:flex;align-items:center;gap:6px}
  .weather-btn:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(16,185,129,0.4)}
  .about-avatar{width:100%;aspect-ratio:1;border-radius:var(--radius-lg);background:linear-gradient(135deg,rgba(16,185,129,0.2),rgba(6,78,59,0.8));display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;border:1px solid var(--glass-border);position:relative;overflow:hidden;max-width:340px}
  .about-avatar::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(16,185,129,0.1),transparent 60%);animation:rotate-glow 8s linear infinite}
  @keyframes rotate-glow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  .avatar-initials{font-family:var(--font-display);font-size:3.5rem;font-weight:800;background:linear-gradient(135deg,var(--emerald-glow),var(--amber-warm));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;position:relative}
  .cert-chip{background:rgba(14,165,233,0.12);border:1px solid rgba(14,165,233,0.25);color:var(--sky-pale);padding:0.3rem 0.8rem;border-radius:50px;font-size:0.78rem;font-weight:600}
  .social-link{display:inline-flex;align-items:center;gap:8px;padding:0.65rem 1.2rem;border-radius:50px;font-size:0.85rem;font-weight:600;text-decoration:none;transition:all var(--transition)}
  .social-link.linkedin{background:rgba(10,102,194,0.15);border:1px solid rgba(10,102,194,0.3);color:#93c5fd}
  .social-link.github{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);color:var(--text-primary)}
  .social-link:hover{transform:translateY(-2px);filter:brightness(1.15)}
  /* ── MOBILE RESPONSIVE ── */
  @media(max-width:768px){
    /* Hero — single column, no animation lag */
    .hero{
      grid-template-columns:1fr!important;
      min-height:auto;
      padding:1.5rem 1rem 2rem;
      gap:1.5rem;
    }
    .hero-content{animation:none!important}
    .hero-visual{order:-1;gap:1rem}
    .hero-title{font-size:2rem!important}
    .hero-subtitle{font-size:0.92rem;margin-bottom:1.5rem}
    .hero-actions{gap:0.75rem}
    .hero-actions a{padding:0.75rem 1.4rem;font-size:0.88rem}
    .hero-stats{gap:1.25rem;margin-top:1.75rem;padding-top:1.5rem}
    .stat-value{font-size:1.4rem}
    /* Weather card compact */
    .weather-temp{font-size:2.5rem!important}
    /* Features — single column */
    .features-grid{grid-template-columns:1fr!important;gap:1rem}
    .feature-card{padding:1.25rem}
    .feature-card:hover{transform:none!important}
    /* Listings — single column */
    .listings-grid{grid-template-columns:1fr!important;gap:1rem}
    .listing-card{padding:1.25rem}
    .listing-card:hover{transform:none!important}
    /* Sections padding */
    section{padding:3rem 1rem!important}
    .section-title{font-size:1.6rem!important}
    /* About section — REMOVE card, show simple bio */
    #kuhusu{padding:2.5rem 1rem!important}
    .about-grid-mobile{display:flex!important;flex-direction:column!important;gap:1.5rem!important}
    .about-avatar-col{display:none!important}
    .about-desktop-grid{grid-template-columns:1fr!important;gap:1.5rem!important}
  }
  @media(max-width:480px){
    .hero-title{font-size:1.75rem!important}
    .hero-stats{flex-wrap:wrap;gap:1rem}
    .hero-stats .stat{min-width:calc(50% - 0.5rem)}
  }
</style>
{% endblock %}

{% block content %}
<div style="max-width:1400px;margin:0 auto;background-image:url('/static/img/farm-bg.jpg');background-size:cover;background-position:center top;background-attachment:fixed;">
  <div class="hero">
    <div class="hero-content">
      <div class="hero-badge">
        <i data-lucide="leaf" style="width:14px;height:14px"></i>
        Jukwaa la Kwanza la Kilimo — Tanzania
      </div>
      <h1 class="hero-title">
        Kilimo cha Kisasa<br/>kwa Wakulima wa<br/>
        <span class="accent">Tanzania 🇹🇿</span>
      </h1>
      <p class="hero-subtitle">AgroLink Tanzania inaunganisha wakulima, mawakala, na masoko kwa teknolojia ya hali ya juu. Pata bei za soko, hali ya hewa, na mashauri ya kilimo — mahali pamoja.</p>
      <div class="hero-actions">
        <a href="{{ url_for('login') }}" class="btn-primary"><i data-lucide="store" style="width:18px;height:18px"></i>Ingia Sokoni</a>
        <a href="{{ url_for('register') }}" class="btn-ghost"><i data-lucide="user-plus" style="width:18px;height:18px"></i>Jisajili Bure</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><div class="stat-value">10K+</div><div class="stat-label">Wakulima</div></div>
        <div class="stat"><div class="stat-value">25+</div><div class="stat-label">Mikoa</div></div>
        <div class="stat"><div class="stat-value">50+</div><div class="stat-label">Aina za Mazao</div></div>
        <div class="stat"><div class="stat-value">24/7</div><div class="stat-label">Msaada</div></div>
      </div>
    </div>
    <div class="hero-visual">
      <!-- Weather Glass Card -->
      <div style="background:rgba(255,255,255,0.07);backdrop-filter:blur(24px) saturate(1.8);-webkit-backdrop-filter:blur(24px) saturate(1.8);border:1px solid rgba(255,255,255,0.15);border-radius:var(--radius-lg);padding:1.75rem;box-shadow:0 8px 32px rgba(0,0,0,0.3),inset 0 1px 0 rgba(255,255,255,0.12);position:relative;overflow:hidden">
        <!-- Subtle inner glow -->
        <div style="position:absolute;top:-40px;right:-40px;width:180px;height:180px;background:radial-gradient(circle,rgba(16,185,129,0.15),transparent 70%);border-radius:50%;pointer-events:none"></div>
        <div style="position:absolute;bottom:-30px;left:-30px;width:140px;height:140px;background:radial-gradient(circle,rgba(14,165,233,0.10),transparent 70%);border-radius:50%;pointer-events:none"></div>
        <!-- Live badge -->
        <div style="display:inline-flex;align-items:center;gap:6px;background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.25);border-radius:50px;padding:0.3rem 0.85rem;font-size:0.72rem;font-weight:700;color:var(--emerald-glow);margin-bottom:1.25rem">
          <div style="width:6px;height:6px;border-radius:50%;background:var(--emerald-bright);animation:pulse-dot 2s ease-in-out infinite"></div>
          Kilimo • Tanzania
        </div>
        <!-- Location -->
        <div style="display:flex;align-items:center;gap:6px;font-size:0.8rem;color:var(--text-secondary);margin-bottom:0.75rem">
          <i data-lucide="map-pin" style="width:13px;height:13px;color:var(--emerald-bright)"></i>
          <span id="weather-city-name">Mbeya, Tanzania</span>
        </div>
        <!-- Temp row -->
        <div style="display:flex;align-items:flex-end;gap:1rem;margin-bottom:1.25rem">
          <div class="weather-temp" id="weather-temp" style="font-size:3.5rem;line-height:1;font-weight:800">--°</div>
          <div style="padding-bottom:0.4rem">
            <div style="font-size:0.9rem;color:var(--text-secondary);text-transform:capitalize;margin-bottom:2px" id="weather-desc">Inapakia...</div>
            <div style="font-size:0.72rem;color:var(--text-muted)">Hali ya Hewa</div>
          </div>
        </div>
        <!-- Divider -->
        <div style="height:1px;background:rgba(255,255,255,0.08);margin-bottom:1.25rem"></div>
        <!-- Stats row -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem">
          <div style="display:flex;flex-direction:column;gap:4px;align-items:center;background:rgba(255,255,255,0.05);border-radius:12px;padding:0.75rem 0.5rem">
            <i data-lucide="droplets" style="width:16px;height:16px;color:var(--sky-cool)"></i>
            <span id="weather-humidity" style="font-family:var(--font-display);font-weight:700;font-size:0.9rem">--%</span>
            <span style="font-size:0.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em">Unyevu</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:4px;align-items:center;background:rgba(255,255,255,0.05);border-radius:12px;padding:0.75rem 0.5rem">
            <i data-lucide="wind" style="width:16px;height:16px;color:var(--sky-cool)"></i>
            <span id="weather-wind" style="font-family:var(--font-display);font-weight:700;font-size:0.9rem">-- m/s</span>
            <span style="font-size:0.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em">Upepo</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:4px;align-items:center;background:rgba(255,255,255,0.05);border-radius:12px;padding:0.75rem 0.5rem">
            <i data-lucide="thermometer" style="width:16px;height:16px;color:var(--amber-warm)"></i>
            <span id="weather-feels" style="font-family:var(--font-display);font-weight:700;font-size:0.9rem">--°C</span>
            <span style="font-size:0.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em">Hisia</span>
          </div>
        </div>
      </div>
      <div class="glass" style="padding:1.5rem">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
          <div style="display:flex;align-items:center;gap:6px;font-family:var(--font-display);font-weight:600;font-size:0.9rem">
            <div class="live-dot"></div>Bei za Soko Leo
          </div>
          <span style="font-size:0.75rem;color:var(--text-muted)">TZS/kg</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.7rem">
          {% if listings %}
            {% for l in listings[:4] %}
            <div class="price-item">
              <div style="display:flex;align-items:center;gap:8px;font-size:0.85rem">
                <i data-lucide="sprout" style="width:14px;height:14px;color:var(--emerald-bright)"></i>
                {{ l.crop_name }}
              </div>
              <div><span class="price-value">{{ "{:,.0f}".format(l.price_tzs) }}</span><span style="font-size:0.72rem;color:var(--text-muted)">/kg</span></div>
            </div>
            {% endfor %}
          {% else %}
            {% for item in [('Mahindi','🌽','850'),('Mpunga','🍚','1,200'),('Viazi','🥔','600'),('Kahawa','☕','4,500')] %}
            <div class="price-item">
              <div style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><span>{{ item[1] }}</span>{{ item[0] }}</div>
              <div><span class="price-value">{{ item[2] }}</span><span style="font-size:0.72rem;color:var(--text-muted)">/kg</span></div>
            </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<!-- FEATURES -->
<section id="huduma">
  <div style="text-align:center;margin-bottom:3.5rem" class="reveal">
    <div class="section-eyebrow">Huduma Zetu</div>
    <h2 class="section-title">Kila Kitu Unachohitaji kwa Kilimo</h2>
    <p class="section-subtitle">Kutoka bei za soko hadi hali ya hewa — AgroLink inakupa nguvu ya kufanya maamuzi sahihi.</p>
  </div>
  <div class="features-grid">
    {% for icon,color,title,desc,tag in [
      ('trending-up','','Bei za Soko la Moja kwa Moja','Pata bei halisi za mazao yako kutoka masoko makuu Tanzania — Kariakoo, Arusha, Mbeya na zaidi.','Bei • Live'),
      ('cloud-sun','amber','Hali ya Hewa kwa Wakulima','Taarifa za hali ya hewa kwa wakati halisi na utabiri wa siku 5 zijazo — zinazosaidia kupanga kilimo chako.','Hewa • API'),
      ('users','sky','Mtandao wa Wakulima','Unganika na wakulima wengine, mawakala wa kilimo, na wanunuzi kutoka kila pembe ya Tanzania.','Mtandao'),
      ('shield-check','','Usalama wa Data','Mfumo wetu umejengwa kwa viwango vya Cisco — data yako inalindwa na usimbaji wa hali ya juu.','Cisco • SSL'),
      ('sprout','amber','Mashauri ya Kilimo','Pata vidokezo vya kitaalamu kuhusu msimu wa kupanda, mbolea, na udhibiti wa wadudu.','Kilimo'),
      ('smartphone','sky','Inapatikana Simu','Tumia AgroLink kwenye simu yako ya kawaida au smartphone — imeundwa kwa wakulima wa Tanzania.','Mobile')
    ] %}
    <div class="feature-card glass reveal" style="position:relative;overflow:hidden">
      <div style="position:absolute;top:1rem;right:1rem;font-size:0.65rem;font-weight:700;letter-spacing:0.08em;color:var(--text-muted);text-transform:uppercase;background:rgba(255,255,255,0.05);padding:2px 8px;border-radius:50px;border:1px solid var(--glass-border)">{{ tag }}</div>
      <div class="feature-icon {{ color }}" style="width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem">
        <i data-lucide="{{ icon }}" style="width:26px;height:26px"></i>
      </div>
      <div class="feature-title">{{ title }}</div>
      <p class="feature-desc">{{ desc }}</p>
    </div>
    {% endfor %}
  </div>
</section>

<!-- MARKET LISTINGS -->
<section id="soko">
  <div style="text-align:center;margin-bottom:3.5rem" class="reveal">
    <div class="section-eyebrow">Soko la AgroLink</div>
    <h2 class="section-title">Orodha za Mazao Zinazopatikana</h2>
    <p class="section-subtitle">Nunua au Uza mazao yako moja kwa moja na wakulima na wanunuzi wa Tanzania.</p>
  </div>
  <div class="listings-grid">
    {% if listings %}
      {% for l in listings %}
      <div class="listing-card glass">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1rem">
          <span class="listing-crop-badge"><i data-lucide="sprout" style="width:12px;height:12px;display:inline;vertical-align:middle"></i> {{ l.crop_name }}</span>
          <span style="display:flex;align-items:center;gap:4px;font-size:0.78rem;color:var(--text-muted)"><i data-lucide="map-pin" style="width:12px;height:12px"></i>{{ l.region }}</span>
        </div>
        <div style="font-family:var(--font-display);font-weight:700;font-size:1rem;margin-bottom:0.5rem">{{ l.title }}</div>
        <div style="display:flex;gap:1.5rem;margin-top:1rem;padding-top:1rem;border-top:1px solid var(--glass-border)">
          <div><div style="font-size:0.72rem;color:var(--text-muted)">Kiasi</div><div class="listing-meta-value">{{ "{:,.0f}".format(l.quantity_kg) }} kg</div></div>
          <div><div style="font-size:0.72rem;color:var(--text-muted)">Bei</div><div class="listing-meta-value">TZS {{ "{:,.0f}".format(l.price_tzs) }}/kg</div></div>
        </div>
        <a href="{{ url_for('login') }}" class="listing-contact-btn" style="display:flex;align-items:center;justify-content:center;gap:6px;text-decoration:none"><i data-lucide="lock" style="width:14px;height:14px"></i>Ingia Kuwasiliana</a>
      </div>
      {% endfor %}
    {% else %}
      <div style="text-align:center;padding:2rem;color:var(--text-muted);grid-column:1/-1">
        <i data-lucide="package-open" style="width:36px;height:36px;margin-bottom:0.75rem;opacity:0.4"></i>
        <p style="font-size:0.9rem">Hakuna orodha bado. <a href="{{ url_for('register') }}" style="color:var(--emerald-glow);text-decoration:none;font-weight:600">Jisajili</a> na uwe wa kwanza kuuza!</p>
      </div>
    {% endif %}
  </div>
  <div style="text-align:center;margin-top:2.5rem">
    <a href="{{ url_for('login') }}" class="btn-primary"><i data-lucide="log-in" style="width:18px;height:18px"></i>Ingia Kuona Orodha Zote</a>
  </div>
</section>

<!-- WEATHER WIDGET -->
<section id="hali-ya-hewa">
  <div style="text-align:center;margin-bottom:3.5rem" class="reveal">
    <div class="section-eyebrow">Hali ya Hewa</div>
    <h2 class="section-title">Angalia Hali ya Hewa Mjini Kwako</h2>
    <p class="section-subtitle">Ingiza jina la mji wako na upate hali ya hewa ya sasa hivi.</p>
  </div>
  <div class="glass" style="max-width:600px;margin:0 auto;padding:2rem;border-radius:var(--radius-lg)" class="reveal">
    <div style="display:flex;gap:0.75rem;margin-bottom:1.5rem">
      <input type="text" id="city-input" class="weather-input" placeholder="Mji wako — Dodoma, Arusha, Dar es Salaam..."/>
      <button class="weather-btn" onclick="fetchWeather()"><i data-lucide="search" style="width:16px;height:16px"></i>Tafuta</button>
    </div>
    <div id="weather-result" style="display:none">
      <div style="font-family:var(--font-display);font-weight:700;font-size:1.2rem;margin-bottom:0.5rem" id="wr-city"></div>
      <div style="display:flex;align-items:flex-end;gap:1rem;margin-bottom:1rem">
        <div class="weather-temp" id="wr-temp"></div>
        <div style="font-size:1rem;color:var(--text-secondary);padding-bottom:0.3rem;text-transform:capitalize" id="wr-desc"></div>
      </div>
      <div style="display:flex;gap:1.5rem">
        <div class="weather-detail"><i data-lucide="droplets" style="width:15px;height:15px;color:var(--sky-cool)"></i><span id="wr-humidity"></span></div>
        <div class="weather-detail"><i data-lucide="wind" style="width:15px;height:15px;color:var(--sky-cool)"></i><span id="wr-wind"></span></div>
      </div>
    </div>
    <div id="weather-error" style="color:#f87171;font-size:0.88rem;display:none"></div>
  </div>
</section>

<!-- ABOUT — responsive, no tall card on mobile -->
<!-- PLATFORM STATS -->
<section id="takwimu" style="padding:4rem clamp(1rem,5vw,4rem);background:rgba(0,0,0,0.25);border-top:1px solid var(--glass-border)">
  <div style="max-width:1400px;margin:0 auto">
    <div style="text-align:center;margin-bottom:3rem" class="reveal">
      <div class="section-eyebrow">Takwimu za Mfumo</div>
      <h2 class="section-title">AgroLink Tanzania kwa Nambari</h2>
      <p class="section-subtitle">Data halisi kutoka kwenye mfumo wetu — inasasishwa mara kwa mara.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;margin-bottom:1rem" class="reveal">
      <!-- Watumiaji -->
      <div style="background:rgba(255,255,255,0.05);border:1px solid var(--glass-border);border-radius:var(--radius-md);padding:2rem;text-align:center;backdrop-filter:blur(12px)">
        <div style="width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,rgba(16,185,129,0.2),rgba(16,185,129,0.05));border:1px solid rgba(16,185,129,0.25);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
          <i data-lucide="users" style="width:22px;height:22px;color:var(--emerald-bright)"></i>
        </div>
        <div style="font-family:var(--font-display);font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,var(--emerald-glow),var(--amber-warm));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">{{ stats.users }}</div>
        <div style="font-size:0.85rem;color:var(--text-secondary);margin-top:0.25rem">Watumiaji Waliojisajili</div>
      </div>
      <!-- Orodha za Mazao -->
      <div style="background:rgba(255,255,255,0.05);border:1px solid var(--glass-border);border-radius:var(--radius-md);padding:2rem;text-align:center;backdrop-filter:blur(12px)">
        <div style="width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,rgba(245,158,11,0.2),rgba(245,158,11,0.05));border:1px solid rgba(245,158,11,0.25);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
          <i data-lucide="package" style="width:22px;height:22px;color:var(--amber-warm)"></i>
        </div>
        <div style="font-family:var(--font-display);font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,var(--emerald-glow),var(--amber-warm));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">{{ stats.listings }}</div>
        <div style="font-size:0.85rem;color:var(--text-secondary);margin-top:0.25rem">Orodha za Mazao</div>
      </div>
      <!-- Mikoa -->
      <div style="background:rgba(255,255,255,0.05);border:1px solid var(--glass-border);border-radius:var(--radius-md);padding:2rem;text-align:center;backdrop-filter:blur(12px)">
        <div style="width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,rgba(14,165,233,0.2),rgba(14,165,233,0.05));border:1px solid rgba(14,165,233,0.25);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
          <i data-lucide="map-pin" style="width:22px;height:22px;color:var(--sky-cool)"></i>
        </div>
        <div style="font-family:var(--font-display);font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,var(--emerald-glow),var(--amber-warm));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">{{ stats.regions }}</div>
        <div style="font-size:0.85rem;color:var(--text-secondary);margin-top:0.25rem">Mikoa Inayofunikwa</div>
      </div>
      <!-- Aina za Mazao -->
      <div style="background:rgba(255,255,255,0.05);border:1px solid var(--glass-border);border-radius:var(--radius-md);padding:2rem;text-align:center;backdrop-filter:blur(12px)">
        <div style="width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,rgba(167,243,208,0.2),rgba(16,185,129,0.05));border:1px solid rgba(52,211,153,0.25);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
          <i data-lucide="sprout" style="width:22px;height:22px;color:var(--emerald-glow)"></i>
        </div>
        <div style="font-family:var(--font-display);font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,var(--emerald-glow),var(--amber-warm));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">{{ stats.crops }}</div>
        <div style="font-size:0.85rem;color:var(--text-secondary);margin-top:0.25rem">Aina za Mazao</div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURED LISTINGS PREVIEW -->
<section id="soko-preview" style="padding:4rem clamp(1rem,5vw,4rem);border-top:1px solid var(--glass-border)">
  <div style="max-width:1400px;margin:0 auto">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem" class="reveal">
      <div>
        <div class="section-eyebrow">Soko la Mazao</div>
        <h2 class="section-title" style="margin-bottom:0.5rem">Mazao Mapya Sokoni</h2>
        <p style="font-size:0.9rem;color:var(--text-secondary)">Orodha za hivi karibuni — ingia ili uone mawasiliano ya muuzaji.</p>
      </div>
      <a href="{{ url_for('login') }}" class="btn-primary" style="white-space:nowrap">
        <i data-lucide="log-in" style="width:16px;height:16px"></i>Ingia Kuona Zaidi
      </a>
    </div>
    {% if listings %}
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem" class="reveal">
      {% for l in listings[:6] %}
      <div style="background:rgba(255,255,255,0.05);border:1px solid var(--glass-border);border-radius:var(--radius-md);padding:1.5rem;backdrop-filter:blur(12px);transition:border-color 0.2s" onmouseover="this.style.borderColor='rgba(16,185,129,0.35)'" onmouseout="this.style.borderColor='var(--glass-border)'">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
          <div style="display:flex;align-items:center;gap:8px">
            <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,rgba(16,185,129,0.2),rgba(16,185,129,0.05));border:1px solid rgba(16,185,129,0.2);display:flex;align-items:center;justify-content:center">
              <i data-lucide="sprout" style="width:16px;height:16px;color:var(--emerald-bright)"></i>
            </div>
            <div>
              <div style="font-weight:700;font-size:0.9rem;color:var(--text-primary)">{{ l.crop_name }}</div>
              <div style="font-size:0.72rem;color:var(--text-muted);display:flex;align-items:center;gap:3px">
                <i data-lucide="map-pin" style="width:10px;height:10px"></i>{{ l.region }}
              </div>
            </div>
          </div>
          <div style="text-align:right">
            <div style="font-family:var(--font-display);font-weight:800;font-size:1.1rem;color:var(--emerald-glow)">{{ "{:,.0f}".format(l.price_tzs) }}</div>
            <div style="font-size:0.68rem;color:var(--text-muted)">TZS/kg</div>
          </div>
        </div>
        <div style="height:1px;background:rgba(255,255,255,0.06);margin-bottom:1rem"></div>
        <!-- Gated contact -->
        <a href="{{ url_for('login') }}" style="display:flex;align-items:center;justify-content:center;gap:6px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:50px;padding:0.5rem 1rem;font-size:0.78rem;font-weight:600;color:var(--emerald-glow);text-decoration:none;transition:all 0.2s" onmouseover="this.style.background='rgba(16,185,129,0.15)'" onmouseout="this.style.background='rgba(16,185,129,0.08)'">
          <i data-lucide="lock" style="width:12px;height:12px"></i>Ingia Kuwasiliana
        </a>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div style="text-align:center;padding:3rem;color:var(--text-muted)">
      <i data-lucide="package-open" style="width:40px;height:40px;margin-bottom:1rem;opacity:0.4"></i>
      <p>Hakuna orodha bado. Kuwa wa kwanza kuongeza!</p>
      <a href="{{ url_for('register') }}" class="btn-primary" style="margin-top:1rem;display:inline-flex">Jisajili Sasa</a>
    </div>
    {% endif %}
  </div>
</section>
{% endblock %}

{% block extra_scripts %}
<script>
async function loadHeroWeather(){
  try{
    const res=await fetch('/weather?city=Mbeya');
    const data=await res.json();
    const w=data.weather;
    if(w.success){
      document.getElementById('weather-temp').textContent=Math.round(w.temperature)+'°C';
      document.getElementById('weather-desc').textContent=w.description;
      document.getElementById('weather-humidity').textContent=w.humidity+'%';
      document.getElementById('weather-wind').textContent=w.wind_speed+' m/s';
      if(w.feels_like)document.getElementById('weather-feels').textContent=Math.round(w.feels_like)+'°C';
    }
  }catch(e){console.warn('Weather unavailable')}
}
async function fetchWeather(){
  const city=document.getElementById('city-input').value.trim();
  if(!city)return;
  document.getElementById('weather-result').style.display='none';
  document.getElementById('weather-error').style.display='none';
  try{
    const res=await fetch('/weather?city='+encodeURIComponent(city));
    const data=await res.json();
    const w=data.weather;
    if(w.success){
      document.getElementById('wr-city').textContent=w.city+', Tanzania';
      document.getElementById('wr-temp').textContent=Math.round(w.temperature)+'°C';
      document.getElementById('wr-desc').textContent=w.description;
      document.getElementById('wr-humidity').textContent='Unyevu: '+w.humidity+'%';
      document.getElementById('wr-wind').textContent='Upepo: '+w.wind_speed+' m/s';
      document.getElementById('weather-result').style.display='block';
      lucide.createIcons();
    }else{
      document.getElementById('weather-error').textContent='Mji "'+city+'" haukupatikana.';
      document.getElementById('weather-error').style.display='block';
    }
  }catch(e){
    document.getElementById('weather-error').textContent='Hitilafu ya mtandao.';
    document.getElementById('weather-error').style.display='block';
  }
}
document.getElementById('city-input').addEventListener('keydown',e=>{if(e.key==='Enter')fetchWeather()});
document.addEventListener('DOMContentLoaded',loadHeroWeather);
</script>
{% endblock %}
